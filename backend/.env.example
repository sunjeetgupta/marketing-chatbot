# LLM Provider — use "groq" for cloud (Railway), "ollama" for local dev
LLM_PROVIDER=groq

# Groq API key — get free at console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq model overrides (optional — defaults are good)
GROQ_MODEL_POWERFUL=llama-3.1-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Ollama settings (only used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ChromaDB — use "memory" on cloud (no persistent disk), "persist" locally
CHROMA_MODE=memory
CHROMA_PERSIST_DIR=./chroma_db

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=https://your-app.vercel.app
